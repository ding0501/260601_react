{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://152.136.182.210:12231/api/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "http://152.136.182.210:12231/images/:path*"
    },

    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
